{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "dev.architectury.loom",
        "dev.architectury.loom:dev.architectury.loom.gradle.plugin",
        "com.replaymod.preprocess",
        "com.replaymod.preprocess:com.replaymod.preprocess.gradle.plugin",

        "net.minecraftforge:forge",
        "net.minecraftforge:forgespi",
        "cpw.mods:modlauncher",

        "net.neoforged.fancymodloader:core",
        "net.neoforged.fancymodloader:language-java",
        "net.neoforged.fancymodloader:loader",
        "net.neoforged:neoforge",

        "net.fabricmc.fabric-api:fabric-api",
        
        "com.mojang:minecraft",

        "maven.modrinth:*"
      ],
      "enabled": false
    }
  ]
}
